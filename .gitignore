# ─── Build directories ───────────────────────────────────────────────
# Out-of-source build trees (preferred). In-source builds are also covered
# by the more specific rules below.
build/
build-*/
out/
cmake-build-*/        # CLion / IDE default build dirs

# ─── CMake generated files ───────────────────────────────────────────
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
CMakeUserPresets.json
install_manifest.txt
Makefile
*.cmake.stamp

# FetchContent / ExternalProject downloads and builds
_deps/

# Build-time-generated shader bytecode headers (in-source build output).
# Out-of-source builds place these under build/ instead.
/generated/

# ─── Visual Studio / MSBuild generator output ────────────────────────
# Generated by `cmake -G "Visual Studio ..."`, including in-source builds.
*.sln
*.slnx
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.dir/
ALL_BUILD.*
ZERO_CHECK.*
INSTALL.*
RUN_TESTS.*
PACKAGE.*
.vs/
*.VC.db
*.VC.opendb

# Default MSBuild output config/platform dirs (anchored to repo root)
/Debug/
/Release/
/RelWithDebInfo/
/MinSizeRel/
/x64/
/x86/
/Win32/
/lib/
/bin/

# ─── Compiled objects, libraries, executables ────────────────────────
*.o
*.obj
*.lo
*.la
*.exe
*.out
*.app
*.so
*.so.*
*.dylib
*.dll
*.a
*.lib
*.pdb
*.ilk
*.exp

# ─── IDE / editor ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ─── Logs, temp, and OS files ────────────────────────────────────────
*.log
*.tmp
.DS_Store
Thumbs.db

# ─── Test output (test *sources* under tests/ are tracked) ───────────
test_detail.xml
Testing/
