# ─── Build directories ───────────────────────────────────────────────
# Out-of-source build trees (preferred). In-source builds are also covered
# by the more specific rules below.
build/
build-*/
out/
cmake-build-*/        # CLion / IDE default build dirs

# ─── CMake generated files ───────────────────────────────────────────
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
CMakeUserPresets.json
install_manifest.txt
Makefile
*.cmake.stamp

# FetchContent / ExternalProject downloads and builds
_deps/

# miniaudio is downloaded at configure time into the build tree (see
# MINIAUDIO_VERSION in CMakeLists.txt), never vendored. Ignore any stray
# copy left at the repo root by a configure run with the wrong working dir.
/_miniaudio/

# ─── Visual Studio / MSBuild generator output ────────────────────────
# Generated by `cmake -G "Visual Studio ..."`, including in-source builds.
*.sln
*.slnx
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.dir/
ALL_BUILD.*
ZERO_CHECK.*
INSTALL.*
RUN_TESTS.*
PACKAGE.*
.vs/
*.VC.db
*.VC.opendb

# Default MSBuild output config/platform dirs (anchored to repo root)
/Debug/
/Release/
/RelWithDebInfo/
/MinSizeRel/
/x64/
/x86/
/Win32/
/lib/
/bin/

# ─── Compiled objects, libraries, executables ────────────────────────
*.o
*.obj
*.lo
*.la
*.exe
*.out
*.app
*.so
*.so.*
*.dylib
*.dll
*.a
*.lib
*.pdb
*.ilk
*.exp

# ─── IDE / editor / agent tooling ────────────────────────────────────
.idea/
.vscode/
.claude/
*.swp
*~

# ─── Logs, temp, and OS files ────────────────────────────────────────
*.log
*.tmp
.DS_Store
Thumbs.db

# ─── Test output (test *sources* under tests/ are tracked) ───────────
test_detail.xml
Testing/

# ─── Demo save-game output (04-build-break-persist writes here) ──────
voxelsave/

# ─── Demo runtime-generated assets (12-soundscape synthesises this) ──
ambient_bed.wav

# ─── Mega-demo (20) runtime-synthesised tiles + sounds ───────────────
assets/textures/overworld/
assets/audio/nature/
